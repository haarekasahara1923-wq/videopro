{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "excludeFiles": "{resource/songs/**,resource/fonts/STHeiti*,resource/fonts/MicrosoftYaHei*,docs/**,test/**,webui/**}"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
